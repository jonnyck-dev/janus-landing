# JANUS Landing — variables de entorno (referencia)
# Para Vercel estático: pega estos valores en el dashboard de Vercel
# (Settings → Environment Variables) O edítalos directo en auth.js.
#
# La ANON KEY es pública por diseño (protegida por Row Level Security).
# NUNCA expongas la service_role key en el frontend.

SUPABASE_URL=TU_SUPABASE_URL
SUPABASE_ANON_KEY=TU_SUPABASE_ANON_KEY

# Redirect OAuth en Supabase / Google Cloud:
#   Supabase: Authentication → Providers → Google → Authorized redirect URLs
#     https://<tu-proyecto>.supabase.co/auth/v1/callback
#   Google Cloud: APIs & Services → Credentials → OAuth client → Authorized JavaScript origins
#     https://janus-landing-red.vercel.app
#     http://localhost:5500   (para desarrollo local)
#   Google Cloud → Authorized redirect URIs:
#     https://<tu-proyecto>.supabase.co/auth/v1/callback
